            <FIELD NAME="points" TYPE="text" NOTNULL="true" SEQUENCE="false"/>
        </FIELDS>
        <KEYS>
            <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        </KEYS>
        <INDEXES>
            <INDEX NAME="course" UNIQUE="false" FIELDS="courseid"/>
        </INDEXES>
    </TABLE>
